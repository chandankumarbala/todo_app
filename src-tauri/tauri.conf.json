{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Do It",
  "version": "0.1.0",
  "identifier": "com.tasklist.doit",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build:static",
    "devUrl": "http://localhost:3847",
    "frontendDist": "../out"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Do It",
        "width": 400,
        "height": 800,
        "decorations": false,
        "alwaysOnTop": true,
        "resizable": true,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "macOS": {
      "minimumSystemVersion": "11.0"
    }
  }
}
